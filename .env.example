# FinReferrals environment variables — copy to .env and fill in.
# NEVER commit a populated .env. Replit Secrets is the production source of truth.

# Required: Telegram bot token from @BotFather (rotate via /revoke if leaked)
TELEGRAM_BOT_TOKEN=PUT_YOUR_TOKEN_HERE

# Required: comma-separated Telegram numeric user IDs that may run admin commands
ADMIN_IDS=111111111,222222222

# Optional: scheduler cycle in hours (clamped to >= 0.1). Default 1.6
SCHED_INTERVAL_HOURS=1.6

# Optional: HTTP health-check port. Default 8000
PORT=8000

# Optional: set to public HTTPS base URL to switch from polling to webhook mode
# Example: https://myapp.onrender.com
# WEBHOOK_URL=
